{
  "name": "aiocs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local-only documentation store, fetcher, and search CLI for AI agents.",
  "bin": {
    "docs": "./dist/cli.js"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "dev": "tsx src/cli.ts",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "better-sqlite3": "^12.4.1",
    "commander": "^14.0.1",
    "jsdom": "^27.0.1",
    "playwright": "^1.57.0",
    "turndown": "^7.2.1",
    "turndown-plugin-gfm": "^1.0.2",
    "yaml": "^2.8.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^24.7.2",
    "@types/turndown": "^5.0.5",
    "execa": "^9.6.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
